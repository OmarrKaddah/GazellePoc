# Get your free key at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# "dev" uses Groq API + local Ollama embeddings (recommended)
# "prod" uses fully on-prem vLLM (see README Production Mode section)
GP_ENV=dev

# Embedding configuration
# EMBEDDING_PROVIDER: local | ollama
# local runs HuggingFace sentence-transformers (e.g., BGE-M3 / multilingual E5)
# ollama runs Ollama embedding models (e.g., nomic-embed-text)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
# Optional: override tokenizer model used for exact token counts (defaults to EMBEDDING_MODEL)
EMBEDDING_TOKENIZER_MODEL=
# Optional: metadata dimension hint (actual Qdrant dim is inferred from real embeddings)
EMBEDDING_DIMENSIONS=1024
OLLAMA_BASE_URL=http://localhost:11434

# Offline mode flags (bank-prem/no internet)
# If any of these are true, Config forces main_llm and fast_llm to OFFLINE_LLM_PROVIDER.
GP_OFFLINE=0
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=0

# Offline LLM override (used when offline mode is enabled)
# OFFLINE_LLM_PROVIDER: ollama_chat | openai_compatible
OFFLINE_LLM_PROVIDER=ollama_chat
OFFLINE_LLM_MODEL=qwen2.5:7b
# For ollama_chat: typically http://localhost:11434
# For openai_compatible: your on-prem endpoint, e.g. http://machine1:8000/v1
OFFLINE_LLM_BASE_URL=http://localhost:11434
OFFLINE_LLM_API_KEY=not-needed

# Graph backend: networkx (default) or neo4j
GRAPH_BACKEND=networkx

# Neo4j connection (used when GRAPH_BACKEND=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=
